---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

const stats = [
  { number: '90-180', label: 'Day engagements' },
  { number: '2-20', label: 'Person teams' },
  { number: 'B2B', label: 'SaaS and services' },
  { number: 'SEO/SEM', label: 'Plus automation' },
];

const fitPills = [
  'Founder-led B2B teams',
  '90-180 day engagements',
  '2-20 person teams',
  'Search, paid, and automation',
];

const focusAreas = [
  {
    title: 'Search strategy built around buyer intent',
    description:
      'We rebuild SEO around the way founders, operators, and revenue leaders actually search when they are diagnosing a problem or evaluating options.',
    features: [
      'High-intent keyword mapping',
      'Pillar-cluster site architecture',
      'Decision-stage landing pages',
      'Content tied to pipeline influence',
    ],
  },
  {
    title: 'Paid search aligned to real jobs-to-be-done',
    description:
      'We tighten campaigns around problem-aware queries, match pages to specific use cases, and remove the gaps between keyword, promise, and activation.',
    features: [
      'Search campaign restructuring',
      'Message-to-page alignment',
      'Offer testing by intent',
      'Lower cost per qualified action',
    ],
  },
  {
    title: 'Automation that replaces manual follow-up',
    description:
      'We connect forms, CRM stages, email, and calendars so qualified leads move to the next step without founders living inside a dozen tools.',
    features: [
      'Behavior-based nurture sequences',
      'Lead routing and lifecycle stages',
      'Calendar and follow-up automation',
      'CRM as a single source of truth',
    ],
  },
  {
    title: 'Measurement that shows what moved revenue',
    description:
      'We build reporting founders can actually use: where demand came from, which pages influenced deals, and where the funnel is leaking.',
    features: [
      'Closed-won content attribution',
      'Source-of-truth dashboards',
      'Funnel leak analysis',
      'Weekly decision-ready reporting',
    ],
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Diagnose the highest-intent opportunity',
    description:
      'We audit acquisition channels, search behavior, and follow-up gaps to find the pages, keywords, and handoffs most likely to unlock pipeline first.',
  },
  {
    number: '02',
    title: 'Prioritize the funnel around buying intent',
    description:
      'We simplify the roadmap so traffic sources, offers, landing pages, and CRM stages all support the same conversion path instead of competing with each other.',
  },
  {
    number: '03',
    title: 'Ship pages, campaigns, and automation in sprints',
    description:
      'Each sprint turns into something live: tighter targeting, clearer messaging, better routing, cleaner attribution, or a stronger onboarding path.',
  },
  {
    number: '04',
    title: 'Measure pipeline and compound the wins',
    description:
      'We track the work against qualified conversations, activated accounts, and revenue influence so the system gets sharper every month.',
  },
];

const clientStories = [
  {
    name: 'Signalboard',
    meta: 'B2B SaaS · Revenue operations analytics · New York',
    pill: 'SEO + Demand Gen',
    metrics: ['+118% organic demo requests', '3x blog-to-pipeline attribution'],
    challenge:
      'Signalboard had a strong product and a handful of champion customers, but search traffic and inbound demos were flat. Content was insightful but misaligned with high-intent keywords and decision-maker pain.',
    built:
      'We rebuilt their SEO strategy around revenue leaders\' real search behavior, shipped a new pillar-cluster architecture, and wired HubSpot to attribute content to closed-won deals.',
    result:
      'Within 5 months, Signalboard doubled organic demos from search and could see exactly which pages moved revenue, not just sessions.',
  },
  {
    name: 'Northline Advisory',
    meta: 'B2B consulting · Leadership and strategy · Remote, US',
    pill: 'Funnels + Automation',
    metrics: ['40%+ calendar fill from inbound', '3-step nurture replacing manual follow-up'],
    challenge:
      'The founder\'s personal brand drove referrals, but there was no consistent way to turn podcast appearances, events, and LinkedIn content into a predictable pipeline.',
    built:
      'We designed a simple insight-to-lead-magnet-to-consult-call funnel, layered in behavior-based email sequences, and connected everything to a single source of truth in their CRM.',
    result:
      'Northline went from chasing follow-ups in spreadsheets to waking up to qualified strategy calls booked automatically each week.',
  },
  {
    name: 'Launchpad OS',
    meta: 'PLG SaaS · Founder tooling · Austin',
    pill: 'SEO + Paid Search',
    metrics: ['-52% cost per trial', '+73% trial-to-activation rate'],
    challenge:
      'Search campaigns and landing pages were built quickly during launch, leading to broad targeting, generic messaging, and a mismatch between keywords and onboarding.',
    built:
      'We rebuilt campaigns around problem-aware queries, matched landing pages to specific jobs-to-be-done, and designed an onboarding flow that nudged users to their first "aha moment" in under 15 minutes.',
    result:
      'Paid acquisition became profitable, and the team could confidently scale budgets into channels that consistently turned clicks into activated accounts.',
  },
  {
    name: 'Fieldnote Logistics',
    meta: 'B2B services · Warehousing and 3PL · Midwest',
    pill: 'Local SEO + Inbound',
    metrics: ['5x qualified RFQs from search', 'New markets opened from inbound'],
    challenge:
      'Sales relied on trade shows and cold outreach. Decision-makers were increasingly researching 3PL partners online before ever talking to a rep.',
    built:
      'We optimized core service pages for geo-intent, overhauled their Google Business Profile, and launched decision-focused content answering the exact questions operations leaders asked before sending an RFP.',
    result:
      'Within one quarter, inbound RFQs became a meaningful pipeline source, often with higher deal sizes than outbound.',
  },
];

const testimonials = [
  {
    quote:
      'Before Benefactor, growth felt like a series of one-off experiments. Within a quarter we had a clear SEO strategy, a working funnel, and a dashboard that finally let us see which levers were actually moving pipeline.',
    name: 'Elena Ruiz',
    role: 'Co-founder and CEO, Signalboard',
    tag: 'RevOps SaaS',
  },
  {
    quote:
      'I did not want another agency sending vanity metrics. Benefactor plugged into our team, owned the numbers, and built systems that keep my calendar full without me living inside a marketing tool.',
    name: 'Marcus Lee',
    role: 'Founder, Northline Advisory',
    tag: 'B2B Consulting',
  },
  {
    quote:
      'What I appreciated most was the focus on compounding wins. Every sprint, we shipped something small but meaningful: better onboarding, tighter campaigns, cleaner data. Six months later, our acquisition economics look completely different.',
    name: 'Jordan Patel',
    role: 'Head of Growth, Launchpad OS',
    tag: 'PLG SaaS',
  },
  {
    quote:
      'Benefactor helped us translate decades of offline expertise into a digital presence that actually brings the right operators to our door. We now treat inbound as seriously as our biggest trade shows.',
    name: 'Christina Ward',
    role: 'VP Sales, Fieldnote Logistics',
    tag: '3PL and Logistics',
  },
];
---

<BaseLayout
  title="Benefactor - Search, Paid, and Automation for Founder-Led B2B"
  description="Benefactor partners with founder-led B2B teams to build search, paid, and automation systems that turn scattered traffic into a reliable pipeline of sales conversations."
>
  <section class="hero section--hero bg-grid bg-radial" id="hero">
    <div class="container">
      <div class="hero__content">
        <div class="badge animate-fade-in-up">
          <span class="badge__dot"></span>
          Selected client stories
        </div>

        <h1 class="hero__title animate-fade-in-up stagger-1">
          Leaner funnels.<br />
          <span class="gradient-text">Sharper intent. Compounding growth.</span>
        </h1>

        <p class="hero__subtitle animate-fade-in-up stagger-2">
          Benefactor partners with founder-led B2B teams to build search, paid, and automation
          systems that turn scattered traffic into a reliable pipeline of sales conversations.
        </p>

        <div class="hero__actions animate-fade-in-up stagger-3">
          <a href="#contact" class="btn btn--primary btn--large" id="hero-cta-primary">
            Book a Strategy Call
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path
                d="M3 8h10M9 4l4 4-4 4"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              ></path>
            </svg>
          </a>
          <a href="#results" class="btn btn--secondary btn--large" id="hero-cta-secondary">
            See Client Portfolio
          </a>
        </div>

        <div class="hero__capabilities animate-fade-in-up stagger-4">
          <span class="hero__capabilities-label">Typical fit</span>
          <div class="hero__capability-badges">
            {fitPills.map((pill) => <span class="hero__capability-badge">{pill}</span>)}
          </div>
        </div>
      </div>
    </div>

    <div class="hero__orb" aria-hidden="true"></div>
    <div class="hero__orb hero__orb--2" aria-hidden="true"></div>
  </section>

  <section class="stats" id="stats-bar">
    <div class="container">
      <div class="stats__grid">
        {stats.map((stat) => (
          <div class="stats__item animate-fade-in-up">
            <span class="stats__number">{stat.number}</span>
            <span class="stats__label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="services section" id="services">
    <div class="container">
      <div class="services__header">
        <span class="badge animate-fade-in-up">What we build</span>
        <h2 class="animate-fade-in-up stagger-1">
          Growth systems that turn intent into <span class="gradient-text">pipeline</span>
        </h2>
        <p class="services__desc animate-fade-in-up stagger-2">
          Search, paid, and automation only work when the handoffs between them are tight. We
          build the pages, campaigns, follow-up, and measurement layers as one system.
        </p>
      </div>

      <div class="services__grid">
        {focusAreas.map((area, index) => (
          <div class="card services__card animate-fade-in-up">
            <div class="services__kicker">{String(index + 1).padStart(2, '0')}</div>
            <h3>{area.title}</h3>
            <p>{area.description}</p>
            <ul class="services__features">
              {area.features.map((feature) => <li>{feature}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="process section bg-noise" id="process">
    <div class="container process__container">
      <div class="process__header">
        <span class="badge animate-fade-in-up">How we work</span>
        <h2 class="animate-fade-in-up stagger-1">
          Fast enough to create momentum, structured enough to <span class="gradient-text">compound</span>
        </h2>
      </div>

      <div class="process__timeline">
        {processSteps.map((step) => (
          <div class="process__step animate-fade-in-up">
            <div class="process__step-number">{step.number}</div>
            <div class="process__step-content">
              <h3>{step.title}</h3>
              <p>{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="portfolio section" id="results" aria-labelledby="portfolio-heading">
    <div class="container">
      <div class="portfolio__header">
        <span class="badge animate-fade-in-up">Client portfolio</span>
        <h2 id="portfolio-heading" class="animate-fade-in-up stagger-1">
          Selected client stories
        </h2>
        <p class="portfolio__desc animate-fade-in-up stagger-2">
          A sample of founder-led teams we support across SaaS, consulting, and education. Names
          and details are anonymized, and results are representative of our typical work.
        </p>
      </div>

      <div class="portfolio__grid">
        {clientStories.map((story) => (
          <article class="card portfolio__card animate-fade-in-up">
            <div class="portfolio__top">
              <div>
                <h3 class="portfolio__name">{story.name}</h3>
                <p class="portfolio__meta">{story.meta}</p>
              </div>
              <span class="portfolio__pill">{story.pill}</span>
            </div>

            <div class="portfolio__metrics">
              {story.metrics.map((metric) => <span class="portfolio__metric">{metric}</span>)}
            </div>

            <div class="portfolio__block">
              <span class="portfolio__label">Challenge</span>
              <p class="portfolio__copy">{story.challenge}</p>
            </div>

            <div class="portfolio__block">
              <span class="portfolio__label">What we built</span>
              <p class="portfolio__copy">{story.built}</p>
            </div>

            <div class="portfolio__block">
              <span class="portfolio__label">Result</span>
              <p class="portfolio__copy">{story.result}</p>
            </div>
          </article>
        ))}
      </div>

      <p class="portfolio__note">
        Client stories on this page use fictional names and anonymized details while reflecting
        the kinds of outcomes and engagements Benefactor creates for founder-led B2B teams.
      </p>
    </div>
  </section>

  <section class="voices section" id="about" aria-labelledby="voices-heading">
    <div class="container">
      <div class="voices__header">
        <span class="badge animate-fade-in-up">Voices from our partners</span>
        <h2 id="voices-heading" class="animate-fade-in-up stagger-1">
          We work best with founders who want a thinking partner, not a task-taker
        </h2>
        <p class="voices__desc animate-fade-in-up stagger-2">
          Here is how partners describe the shift after Benefactor tightened their messaging,
          funnels, and growth systems.
        </p>
      </div>

      <div class="voices__grid">
        {testimonials.map((testimonial) => (
          <figure class="card voices__card animate-fade-in-up">
            <blockquote class="voices__quote">{testimonial.quote}</blockquote>
            <figcaption class="voices__author">
              <div>
                <p class="voices__name">{testimonial.name}</p>
                <p class="voices__role">{testimonial.role}</p>
              </div>
              <span class="voices__tag">{testimonial.tag}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="cta section bg-radial-navy" id="contact">
    <div class="container">
      <div class="cta__content animate-fade-in-up">
        <h2>
          Ready to turn scattered traffic into a <span class="gradient-text">reliable pipeline</span>?
        </h2>
        <p>
          Whether you need tighter search intent, cleaner paid acquisition, or automation that
          actually reduces founder workload, we will build a plan around the bottleneck that
          matters most.
        </p>
        <div class="cta__actions">
          <a href="mailto:hello@benefactor.cc" class="btn btn--primary btn--large" id="cta-contact-btn">
            Schedule a Strategy Call
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path
                d="M3 8h10M9 4l4 4-4 4"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              ></path>
            </svg>
          </a>
          <a href="#results" class="btn btn--secondary btn--large" id="cta-services-btn">
            Review Client Stories
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    min-height: 90vh;
    display: flex;
    align-items: center;
  }

  .hero__content {
    max-width: 820px;
  }

  .hero__title {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-lg);
  }

  .hero__subtitle {
    font-size: 1.2rem;
    max-width: 680px;
    margin-bottom: var(--space-2xl);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-3xl);
  }

  .badge__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--bf-success);
    display: inline-block;
    animation: pulseGlow 2s ease-in-out infinite;
  }

  .hero__capabilities-label {
    font-size: 0.8rem;
    color: var(--bf-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 500;
    display: block;
    margin-bottom: var(--space-sm);
  }

  .hero__capability-badges {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .hero__capability-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--bf-text-secondary);
    background: var(--bf-surface);
    border: 1px solid var(--bf-border);
    border-radius: var(--radius-full);
    transition: all var(--duration-normal) var(--ease-out);
  }

  .hero__capability-badge:hover {
    border-color: var(--bf-border-active);
    color: var(--bf-red);
  }

  .hero__orb {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(230, 57, 70, 0.05), transparent 70%);
    top: -15%;
    right: -15%;
    animation: float 8s ease-in-out infinite;
    pointer-events: none;
  }

  .hero__orb--2 {
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(30, 58, 95, 0.08), transparent 70%);
    bottom: 10%;
    right: 20%;
    top: auto;
    animation-delay: -4s;
  }

  .stats {
    padding: var(--space-3xl) 0;
    border-top: 1px solid var(--bf-border);
    border-bottom: 1px solid var(--bf-border);
    background: var(--bf-surface);
  }

  .stats__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-xl);
    text-align: center;
  }

  .stats__number {
    font-size: clamp(1.9rem, 3vw, 2.5rem);
    font-weight: 800;
    background: linear-gradient(135deg, var(--bf-red-light), var(--bf-red));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: block;
  }

  .stats__label {
    font-size: 0.85rem;
    color: var(--bf-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
    margin-top: var(--space-xs);
    display: block;
  }

  .services__header,
  .process__header,
  .portfolio__header,
  .voices__header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .services__header h2,
  .process__header h2,
  .portfolio__header h2,
  .voices__header h2 {
    margin-top: var(--space-md);
  }

  .services__desc,
  .portfolio__desc,
  .voices__desc {
    max-width: 720px;
    margin: var(--space-md) auto 0;
  }

  .services__grid,
  .portfolio__grid,
  .voices__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-xl);
  }

  .services__card h3 {
    margin-bottom: var(--space-sm);
    font-size: 1.25rem;
  }

  .services__card p {
    font-size: 0.95rem;
    margin-bottom: var(--space-lg);
  }

  .services__kicker {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: var(--radius-md);
    background: var(--bf-red-glow);
    color: var(--bf-red);
    border: 1px solid rgba(230, 57, 70, 0.15);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: var(--space-lg);
  }

  .services__features {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .services__features li {
    font-size: 0.85rem;
    color: var(--bf-text-secondary);
    padding-left: 1rem;
    position: relative;
  }

  .services__features li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--bf-red);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .process__container {
    position: relative;
    z-index: 1;
  }

  .process__timeline {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-xl);
  }

  .process__step {
    display: flex;
    gap: var(--space-lg);
    padding: var(--space-2xl);
    border-radius: var(--radius-lg);
    background: var(--bf-surface);
    border: 1px solid var(--bf-border);
    transition: all var(--duration-normal) var(--ease-out);
  }

  .process__step:hover {
    border-color: var(--bf-border-active);
  }

  .process__step-number {
    font-size: 2rem;
    font-weight: 800;
    color: var(--bf-red);
    opacity: 0.3;
    flex-shrink: 0;
    line-height: 1;
  }

  .process__step-content h3 {
    font-size: 1.1rem;
    margin-bottom: var(--space-sm);
  }

  .process__step-content p {
    font-size: 0.95rem;
  }

  .portfolio__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .portfolio__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .portfolio__name {
    font-size: 1.2rem;
    margin-bottom: var(--space-xs);
  }

  .portfolio__meta {
    font-size: 0.88rem;
    color: var(--bf-text-muted);
  }

  .portfolio__pill,
  .portfolio__metric,
  .voices__tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-full);
    border: 1px solid var(--bf-border-hover);
    background: rgba(255, 255, 255, 0.02);
    color: var(--bf-text-primary);
  }

  .portfolio__pill {
    padding: 0.45rem 0.8rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .portfolio__metrics {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .portfolio__metric {
    padding: 0.45rem 0.8rem;
    font-size: 0.8rem;
    color: var(--bf-text-secondary);
  }

  .portfolio__block {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .portfolio__label {
    font-size: 0.74rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--bf-text-muted);
  }

  .portfolio__copy {
    font-size: 0.95rem;
    color: var(--bf-text-secondary);
  }

  .portfolio__note {
    max-width: 820px;
    margin: var(--space-xl) auto 0;
    text-align: center;
    font-size: 0.9rem;
    color: var(--bf-text-muted);
  }

  .voices__card {
    position: relative;
    overflow: hidden;
  }

  .voices__card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top right, rgba(230, 57, 70, 0.08), transparent 50%);
    pointer-events: none;
  }

  .voices__quote {
    position: relative;
    font-size: 1rem;
    line-height: 1.8;
    color: var(--bf-text-primary);
    font-style: italic;
    margin-bottom: var(--space-xl);
    padding-left: 1.1rem;
  }

  .voices__quote::before {
    content: '"';
    position: absolute;
    left: 0;
    top: -0.9rem;
    font-size: 3rem;
    line-height: 1;
    color: rgba(255, 255, 255, 0.14);
  }

  .voices__author {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: var(--space-md);
  }

  .voices__name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--bf-text-primary);
  }

  .voices__role {
    font-size: 0.84rem;
